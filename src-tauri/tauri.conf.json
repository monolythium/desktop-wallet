{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monolythium Wallet",
  "version": "0.0.1",
  "identifier": "com.monolythium.wallet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Monolythium Wallet",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Finance",
    "shortDescription": "Monolythium desktop wallet",
    "longDescription": "Monolythium desktop wallet (macOS, Windows, Linux). Hold and move MNLX, manage keys via the OS keychain, and route every destructive action through a typed Operations drawer."
  }
}
